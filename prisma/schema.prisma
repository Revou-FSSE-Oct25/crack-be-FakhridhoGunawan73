generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kos      Kos[]
  bookings Booking[]

  @@map("users")
}

model Kos {
  id          Int      @id @default(autoincrement())
  ownerId     Int
  name        String
  address     String
  city        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User   @relation(fields: [ownerId], references: [id])
  rooms Room[]

  @@map("kos")
}

model Room {
  id          Int      @id @default(autoincrement())
  kosId       Int
  roomNumber  String
  type        String   @default("Standard")
  price       Int
  capacity    Int      @default(1)
  facilities  String?
  imageUrl    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kos      Kos       @relation(fields: [kosId], references: [id])
  bookings Booking[]

  @@unique([kosId, roomNumber])
  @@map("rooms")
}

model Booking {
  id        Int           @id @default(autoincrement())
  userId    Int
  roomId    Int
  startDate DateTime
  endDate   DateTime
  status    BookingStatus @default(PENDING)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])
  room Room @relation(fields: [roomId], references: [id])

  @@map("bookings")
}